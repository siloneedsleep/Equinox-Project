# ==============================================================================
# 🔑 LUMINOUS NETWORK - CORE CREDENTIALS
# ==============================================================================

# Token bí mật của Discord Bot (Lấy từ Discord Developer Portal)
# Lưu ý: Tuyệt đối không chia sẻ hoặc push file này lên GitHub công khai!
DISCORD_TOKEN=DÁN_TOKEN_BOT_CỦA_SẾP_VÀO_ĐÂY

# ==============================================================================
# 👑 SYSTEM AUTHORITY & PERMISSIONS (USER IDs)
# ==============================================================================

# ID tài khoản Discord tối cao của Sếp (Owner - Slot cứng duy nhất)
OWNER_ID=123456789012345678

# ==============================================================================
# 📺 GLOBAL AUDIT LOGS & STREAM CHANNELS
# ==============================================================================

# Webhook URL nhận các báo cáo log hệ thống tốc độ cao (Lỗi nghẽn mạch, Blacklist, Kỷ luật Staff)
# Bắn thẳng về kênh ẩn tại máy chủ Nhà Chính (HQ)
WEBHOOK_LOGS_URL=https://discord.com/api/webhooks/xxxxxxxxx/xxxxxxxxx
